@inject NavigationManager Navigation

@* Sends an unauthenticated visitor to the login page, preserving where they were headed. Used
   by AuthorizeRouteView for in-circuit navigation; the cookie handler covers the initial
   request. *@

@code {
    protected override void OnInitialized()
    {
        var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);

        Navigation.NavigateTo($"/login?returnUrl=/{Uri.EscapeDataString(returnUrl)}", forceLoad: true);
    }
}
