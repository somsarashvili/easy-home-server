@* A plain yes/no, for an action whose consequence needs a sentence rather than a dialog of its own. *@

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body1">@Title</MudText>

        <MudAlert Severity="@Severity" Variant="Variant.Outlined" Dense="true" Class="mt-3">
            @Message
        </MudAlert>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">Cancel</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled"
                   OnClick="@(() => MudDialog.Close(DialogResult.Ok(true)))">
            @ConfirmText
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>The question, in a line.</summary>
    [Parameter]
    [EditorRequired]
    public required string Title { get; set; }

    /// <summary>What happens if they say yes.</summary>
    [Parameter]
    [EditorRequired]
    public required string Message { get; set; }

    /// <summary>The confirming button's label. Says the action, not "OK".</summary>
    [Parameter]
    public string ConfirmText { get; set; } = "Continue";

    /// <summary>How loud to be.</summary>
    [Parameter]
    public Severity Severity { get; set; } = Severity.Warning;
}
