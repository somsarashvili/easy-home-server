@inject DockerCli Cli

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Storage" Class="mr-2" />
            <MudText Typo="Typo.h6">New volume</MudText>
        </div>
    </TitleContent>

    <DialogContent>
        <MudTextField @bind-Value="_name"
                      Label="Name"
                      Immediate="true"
                      Error="@(_error is not null)"
                      ErrorText="@_error"
                      HelperText="Referenced from a container as name:/path/in/container." />

        @* The reason this option exists: a volume left in Docker's own directory is buried on
           whichever disk Docker lives on, which is rarely the one being backed up. *@
        <MudCheckBox @bind-Value="_useHostPath" Color="Color.Primary" Dense="true" Class="mt-4"
                     Label="Store its data at a path I choose" />

        @if (_useHostPath)
        {
            <MudTextField @bind-Value="_hostPath"
                          Label="Host path"
                          Immediate="true"
                          Placeholder="@SuggestedPath"
                          Class="ml-8"
                          HelperText="An absolute path. Created if it does not exist. Put it somewhere your backups cover." />

            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block ml-8 mt-1">
                It stays a normal named volume — compose refers to it by name — but the bytes live here
                instead of under <code>/var/lib/docker/volumes</code>.
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block ml-8">
                Data goes under <code>/var/lib/docker/volumes</code>, on whichever disk Docker lives on.
            </MudText>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="@(() => Dialog.Cancel())" Disabled="_busy">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="_busy">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance Dialog { get; set; } = default!;

    /// <summary>A concrete example under a path a home server would plausibly back up.</summary>
    private string SuggestedPath => $"/srv/data/{(_name.Length > 0 ? _name : "myvolume")}";

    private string _name = string.Empty;
    private string _hostPath = string.Empty;
    private bool _useHostPath;
    private string? _error;
    private bool _busy;

    private async Task CreateAsync()
    {
        // Docker's own rule for volume names.
        if (string.IsNullOrWhiteSpace(_name)
            || !System.Text.RegularExpressions.Regex.IsMatch(_name, "^[a-zA-Z0-9][a-zA-Z0-9_.-]*$"))
        {
            _error = "Start with a letter or digit; letters, digits, dots, dashes and underscores only.";

            return;
        }

        if (_useHostPath && !_hostPath.StartsWith('/'))
        {
            // A relative path here would be resolved against the service's working directory,
            // which is not a place anyone means.
            _error = "The host path must be absolute, for example /srv/data/myvolume.";

            return;
        }

        _busy = true;
        _error = null;

        try
        {
            var result = await Cli.CreateVolumeAsync(_name, _useHostPath ? _hostPath.Trim() : null);

            if (!result.Succeeded)
            {
                _error = result.Message;

                return;
            }

            Dialog.Close(DialogResult.Ok(_name));
        }
        finally
        {
            _busy = false;
        }
    }
}
