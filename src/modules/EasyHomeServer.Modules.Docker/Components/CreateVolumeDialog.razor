@inject DockerCli Cli

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Storage" Class="mr-2" />
            <MudText Typo="Typo.h6">New volume</MudText>
        </div>
    </TitleContent>

    <DialogContent>
        <MudTextField @bind-Value="_name"
                      Label="Name"
                      Immediate="true"
                      Error="@(_error is not null)"
                      ErrorText="@_error"
                      HelperText="Referenced from a container as name:/path/in/container." />
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="@(() => Dialog.Cancel())" Disabled="_busy">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="_busy">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance Dialog { get; set; } = default!;

    private string _name = string.Empty;
    private string? _error;
    private bool _busy;

    private async Task CreateAsync()
    {
        // Docker's own rule for volume names.
        if (string.IsNullOrWhiteSpace(_name)
            || !System.Text.RegularExpressions.Regex.IsMatch(_name, "^[a-zA-Z0-9][a-zA-Z0-9_.-]*$"))
        {
            _error = "Start with a letter or digit; letters, digits, dots, dashes and underscores only.";

            return;
        }

        _busy = true;
        _error = null;

        try
        {
            var result = await Cli.CreateVolumeAsync(_name);

            if (!result.Succeeded)
            {
                _error = result.Message;

                return;
            }

            Dialog.Close(DialogResult.Ok(_name));
        }
        finally
        {
            _busy = false;
        }
    }
}
