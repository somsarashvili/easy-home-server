@page "/docker"
@attribute [Authorize]
@implements IDisposable

@inject IEventBus EventBus
@inject DockerPoller Poller
@inject DockerCli Cli
@inject ComposeCli Compose
@inject MacvlanShim Shim
@inject DockerOptions Options
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<link rel="stylesheet" href="_content/EasyHomeServer.Modules.Docker/docker.css" />

<PageTitle>Docker</PageTitle>

<div class="d-flex align-center justify-space-between mb-6">
    <div>
        <MudText Typo="Typo.h4">Docker</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            @if (Poller.Availability is { IsAvailable: true, Version: { } version })
            {
                @($"Engine {version}")

                @if (_snapshot is not null)
                {
                    @($" · {_snapshot.RunningCount} of {_snapshot.Containers.Length} containers running · {Format.Bytes(_snapshot.ImageBytes)} of images")
                }
            }
            else
            {
                @("Not connected")
            }
        </MudText>
    </div>
</div>

@if (!Poller.Availability.IsAvailable)
{
    @* Distinguishes "not installed" from "not running": the fix differs, so the page says which. *@
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        <MudText Typo="Typo.subtitle2">Docker is unavailable</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1">@Poller.Availability.Reason</MudText>
    </MudAlert>
}
else if (_snapshot is null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
    <MudText Typo="Typo.body2" Class="mud-text-secondary">Reading the daemon…</MudText>
}
else
{
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" Class="dk-tabs">

        <MudTabPanel Text="@($"Services ({_snapshot.Projects.Length})")" Icon="@Icons.Material.Filled.Dashboard">
            <div class="d-flex align-center justify-space-between mb-4">
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    Compose projects, found from running containers and from
                    <code>@Options.ComposeProjectsPath</code>.
                </MudText>

                @if (Options.AllowCreate && _composeAvailable)
                {
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Small" OnClick="NewProject">
                        New project
                    </MudButton>
                }
            </div>

            @if (!_composeAvailable)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                    <MudText Typo="Typo.subtitle2">Compose is not installed</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1">
                        Install it with <code>apt install docker-compose</code>. Existing projects are still
                        listed below, but cannot be managed from here.
                    </MudText>
                </MudAlert>
            }

            @if (_snapshot.Projects.Length == 0)
            {
                <MudPaper Class="pa-8 d-flex flex-column align-center mt-4" Elevation="0">
                    <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Large" Class="mud-text-secondary mb-3" />
                    <MudText Typo="Typo.h6" GutterBottom="true">No compose projects</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary" Align="Align.Center">
                        A compose project groups related containers into one unit you start and stop together.
                    </MudText>
                </MudPaper>
            }
            else
            {
                @foreach (var project in _snapshot.Projects)
                {
                    <MudPaper Class="pa-4 mb-4" Elevation="0">
                        <div class="d-flex align-center justify-space-between mb-3">
                            <div>
                                <div class="d-flex align-center">
                                    <MudText Typo="Typo.h6">@project.Name</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="@ProjectColor(project)"
                                             Variant="Variant.Filled" Class="ml-3 dk-chip">
                                        @ProjectLabel(project)
                                    </MudChip>

                                    @if (!project.IsManaged)
                                    {
                                        @* Its file lives somewhere this module does not own, so it is
                                           shown and controlled but never rewritten. *@
                                        <MudTooltip Text="Defined outside the projects directory, so it can be started and stopped here but not edited.">
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                     Color="Color.Default" Class="ml-2 dk-chip">external</MudChip>
                                        </MudTooltip>
                                    }
                                </div>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary dk-mono">
                                    @(project.ConfigFiles.FirstOrDefault() ?? "(compose file not known)")
                                </MudText>
                            </div>

                            @* Not gated on the project having containers: a project with none is
                               precisely the state that used to be impossible to get out of. *@
                            @if (Options.AllowContainerControl && _composeAvailable && project.IsActionable)
                            {
                                <div class="d-flex align-center">
                                    @if (_projectBusy == project.Name)
                                    {
                                        <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" Class="mr-3" />
                                    }

                                    @if (project.IsManaged)
                                    {
                                        <MudTooltip Text="Edit compose file">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                           aria-label="@($"Edit compose file for {project.Name}")"
                                                           Disabled="@(_projectBusy is not null)"
                                                           OnClick="@(() => EditProject(project))" />
                                        </MudTooltip>
                                    }

                                    <MudTooltip Text="Pull newer images">
                                        <MudIconButton Icon="@Icons.Material.Filled.CloudDownload" Size="Size.Small"
                                                       aria-label="@($"Pull images for {project.Name}")"
                                                       Disabled="@(_projectBusy is not null)"
                                                       OnClick="@(() => RunProject(project, "Pulled images for", () => Compose.PullAsync(project)))" />
                                    </MudTooltip>

                                    @if (project.Status is ComposeProjectStatus.Running or ComposeProjectStatus.Partial)
                                    {
                                        <MudTooltip Text="Restart">
                                            <MudIconButton Icon="@Icons.Material.Filled.RestartAlt" Size="Size.Small"
                                                           aria-label="@($"Restart {project.Name}")"
                                                           Disabled="@(_projectBusy is not null)"
                                                           OnClick="@(() => RunProject(project, "Restarted", () => Compose.RestartAsync(project)))" />
                                        </MudTooltip>
                                        <MudTooltip Text="Stop (containers are kept)">
                                            <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small" Color="Color.Warning"
                                                           aria-label="@($"Stop {project.Name}")"
                                                           Disabled="@(_projectBusy is not null)"
                                                           OnClick="@(() => RunProject(project, "Stopped", () => Compose.StopAsync(project)))" />
                                        </MudTooltip>
                                    }
                                    else
                                    {
                                        <MudTooltip Text="Start">
                                            <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                                           aria-label="@($"Start {project.Name}")"
                                                           Disabled="@(_projectBusy is not null)"
                                                           OnClick="@(() => RunProject(project, "Started", () => Compose.UpAsync(project)))" />
                                        </MudTooltip>
                                    }

                                    @* Down and Delete are different things and used to share the
                                       trash icon, which made "remove the containers" look like
                                       "remove the project". Down clears the stack; Delete is the
                                       one that is gone for good. *@
                                    <MudTooltip Text="Down — stop and remove containers and networks, keeping the compose file">
                                        <MudIconButton Icon="@Icons.Material.Filled.LayersClear" Size="Size.Small" Color="Color.Error"
                                                       aria-label="@($"Take {project.Name} down")"
                                                       Disabled="@(_projectBusy is not null)"
                                                       OnClick="@(() => DownProject(project))" />
                                    </MudTooltip>

                                    @if (project.IsManaged)
                                    {
                                        @* Only for projects whose file this module owns. An external
                                           project's file lives somewhere we have no business deleting. *@
                                        <MudTooltip Text="Delete — take down and remove the compose file">
                                            <MudIconButton Icon="@Icons.Material.Filled.DeleteForever" Size="Size.Small" Color="Color.Error"
                                                           aria-label="@($"Delete {project.Name}")"
                                                           Disabled="@(_projectBusy is not null)"
                                                           OnClick="@(() => DeleteProject(project))" />
                                        </MudTooltip>
                                    }
                                </div>
                            }
                        </div>

                        @if (project.Services.Length == 0)
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                Defined but not created. Start it to bring its services up.
                            </MudText>
                        }
                        else
                        {
                            <MudSimpleTable Dense="true" Hover="true" Elevation="0" Class="dk-table">
                                <thead>
                                    <tr>
                                        <th>Service</th>
                                        <th>Image</th>
                                        <th>Containers</th>
                                        <th>Ports</th>
                                        <th class="dk-actions">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var service in project.Services)
                                    {
                                        var first = service.Containers.FirstOrDefault();

                                        <tr>
                                            <td>
                                                @if (first is not null)
                                                {
                                                    <a class="dk-link" href="@($"/docker/container/{first.ShortId}")">@service.Name</a>
                                                }
                                                else
                                                {
                                                    <b>@service.Name</b>
                                                }
                                            </td>
                                            <td class="mud-text-secondary">@service.Image</td>
                                            <td>
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                         Color="@(service.RunningCount == service.Containers.Length ? Color.Success : Color.Warning)"
                                                         Class="dk-chip">
                                                    @service.RunningCount / @service.Containers.Length running
                                                </MudChip>
                                            </td>
                                            <td class="dk-ports">
                                                @if (first is null || first.Ports.Length == 0)
                                                {
                                                    <span class="mud-text-secondary">—</span>
                                                }
                                                else
                                                {
                                                    @foreach (var port in first.Ports)
                                                    {
                                                        @if (first.IsRunning && IsLinkable(port))
                                                        {
                                                            <a class="dk-port" href="@PortUrl(port)" target="_blank" rel="noopener">
                                                                @port.HostPort<span class="mud-text-secondary">:@port.ContainerPort</span>
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <span class="dk-port dk-port-plain">
                                                                @port.HostPort<span class="mud-text-secondary">:@port.ContainerPort</span>
                                                            </span>
                                                        }
                                                    }
                                                }
                                            </td>
                                            <td class="dk-actions">
                                                @if (first is not null)
                                                {
                                                    <MudTooltip Text="Logs">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Article" Size="Size.Small"
                                                                       OnClick="@(() => ShowLogs(first))" />
                                                    </MudTooltip>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                    </MudPaper>
                }
            }
        </MudTabPanel>

        <MudTabPanel Text="@($"Containers ({_snapshot.Containers.Length})")" Icon="@Icons.Material.Filled.ViewInAr">
            @if (Options.AllowCreate)
            {
                <div class="d-flex justify-end mb-3">
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Small" OnClick="NewContainer">
                        New container
                    </MudButton>
                </div>
            }

            @if (_snapshot.Containers.Length == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">No containers.</MudText>
            }
            else
            {
                <MudSimpleTable Dense="true" Hover="true" Elevation="0" Class="dk-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Image</th>
                            <th>State</th>
                            <th>Ports</th>
                            <th>Uptime</th>
                            <th class="dk-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var container in OrderedContainers)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-center">
                                        <a class="dk-link" href="@($"/docker/container/{container.ShortId}")">@container.Name</a>
                                        @if (container.ComposeProject is { } project)
                                        {
                                            <MudTooltip Text="@($"Part of the '{project}' compose project")">
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                         Color="Color.Default" Class="ml-2 dk-chip">@project</MudChip>
                                            </MudTooltip>
                                        }
                                    </div>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary dk-mono">@container.ShortId</MudText>
                                </td>
                                <td class="mud-text-secondary">@container.Image</td>
                                <td>
                                    <MudChip T="string" Size="Size.Small" Color="@StateColor(container)" Variant="Variant.Filled">
                                        @StateLabel(container)
                                    </MudChip>
                                </td>
                                <td class="dk-ports">
                                    @if (container.Ports.Length == 0)
                                    {
                                        <span class="mud-text-secondary">—</span>
                                    }
                                    else
                                    {
                                        @foreach (var port in container.Ports)
                                        {
                                            @* Only linked when reachable: a port bound to 127.0.0.1 on the
                                               server is not reachable from the browser's machine. *@
                                            @if (container.IsRunning && IsLinkable(port))
                                            {
                                                <a class="dk-port" href="@PortUrl(port)" target="_blank" rel="noopener">
                                                    @port.HostPort<span class="mud-text-secondary">:@port.ContainerPort</span>
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="dk-port dk-port-plain">
                                                    @port.HostPort<span class="mud-text-secondary">:@port.ContainerPort</span>
                                                </span>
                                            }
                                        }
                                    }
                                </td>
                                <td class="dk-numeric">
                                    @(container.Uptime is { } uptime ? Format.Duration(uptime) : "—")
                                </td>
                                <td class="dk-actions">
                                    <MudTooltip Text="Logs">
                                        <MudIconButton Icon="@Icons.Material.Filled.Article" Size="Size.Small"
                                                       OnClick="@(() => ShowLogs(container))" />
                                    </MudTooltip>

                                    @if (Options.AllowContainerControl)
                                    {
                                        @if (container.IsRunning)
                                        {
                                            <MudTooltip Text="Restart">
                                                <MudIconButton Icon="@Icons.Material.Filled.RestartAlt" Size="Size.Small"
                                                               Disabled="@IsBusy(container)"
                                                               OnClick="@(() => Run(container, "Restarted", () => Cli.RestartAsync(container.Id, 10)))" />
                                            </MudTooltip>
                                            <MudTooltip Text="Stop">
                                                <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small" Color="Color.Warning"
                                                               Disabled="@IsBusy(container)"
                                                               OnClick="@(() => Run(container, "Stopped", () => Cli.StopAsync(container.Id, 10)))" />
                                            </MudTooltip>
                                        }
                                        else
                                        {
                                            <MudTooltip Text="Start">
                                                <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                                               Disabled="@IsBusy(container)"
                                                               OnClick="@(() => Run(container, "Started", () => Cli.StartAsync(container.Id)))" />
                                            </MudTooltip>
                                        }

                                        <MudTooltip Text="Remove">
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                           Disabled="@IsBusy(container)"
                                                           OnClick="@(() => RemoveContainer(container))" />
                                        </MudTooltip>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="@($"Images ({_snapshot.Images.Length})")" Icon="@Icons.Material.Filled.Layers">
            <div class="d-flex justify-end mb-3">
                @if (Options.AllowContainerControl && _snapshot.Images.Any(i => i.IsDangling))
                {
                    <MudButton StartIcon="@Icons.Material.Filled.CleaningServices" Variant="Variant.Outlined"
                               Size="Size.Small" OnClick="PruneImages">
                        Prune @(_snapshot.Images.Count(i => i.IsDangling)) dangling
                    </MudButton>
                }
            </div>

            <MudSimpleTable Dense="true" Hover="true" Elevation="0" Class="dk-table">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Id</th>
                        <th class="dk-numeric">Size</th>
                        <th>Created</th>
                        <th>Used by</th>
                        <th class="dk-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var image in _snapshot.Images.OrderByDescending(i => i.SizeBytes))
                    {
                        <tr>
                            <td>
                                <b class="@(image.IsDangling ? "mud-text-secondary" : "")">@image.DisplayName</b>
                                @if (image.Tags.Length > 1)
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">
                                        +@(image.Tags.Length - 1) more tag@(image.Tags.Length == 2 ? "" : "s")
                                    </MudText>
                                }
                            </td>
                            <td class="mud-text-secondary dk-mono">@image.ShortId</td>
                            <td class="dk-numeric">@Format.Bytes(image.SizeBytes)</td>
                            <td class="mud-text-secondary">@Format.Ago(image.CreatedAt)</td>
                            <td>
                                @if (image.UsedByContainers > 0)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="dk-chip">
                                        @image.UsedByContainers container@(image.UsedByContainers == 1 ? "" : "s")
                                    </MudChip>
                                }
                                else
                                {
                                    <span class="mud-text-secondary">—</span>
                                }
                            </td>
                            <td class="dk-actions">
                                @if (Options.AllowContainerControl)
                                {
                                    <MudTooltip Text="@(image.UsedByContainers > 0 ? "In use by a container" : "Remove")">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                       Disabled="@(image.UsedByContainers > 0)"
                                                       OnClick="@(() => RemoveImage(image))" />
                                    </MudTooltip>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudTabPanel>

        <MudTabPanel Text="@($"Volumes ({_snapshot.Volumes.Length})")" Icon="@Icons.Material.Filled.Storage">
            @if (Options.AllowCreate)
            {
                <div class="d-flex justify-end mb-3">
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Small" OnClick="NewVolume">
                        New volume
                    </MudButton>
                </div>
            }

            @if (_snapshot.Volumes.Length == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">No volumes.</MudText>
            }
            else
            {
                <MudSimpleTable Dense="true" Hover="true" Elevation="0" Class="dk-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Driver</th>
                            <th>Stored at</th>
                            <th>Used by</th>
                            <th class="dk-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var volume in _snapshot.Volumes.OrderBy(v => v.Name, StringComparer.Ordinal))
                        {
                            <tr>
                                <td><b>@volume.Name</b></td>
                                <td class="mud-text-secondary">@volume.Driver</td>
                                <td class="dk-mono dk-path">
                                    @* The real backing path, not Mountpoint. For a bound volume
                                       Docker reports its own directory there, and that directory is
                                       empty whenever no container is running — so a backup planned
                                       from it would silently capture nothing. *@
                                    <span class="mud-text-secondary">@volume.BackingPath</span>

                                    @if (volume.IsBoundToPath)
                                    {
                                        <MudTooltip Text="Stored outside Docker's own directory, so it can be backed up with the rest of that path.">
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                     Color="Color.Success" Class="ml-2 dk-chip">bound</MudChip>
                                        </MudTooltip>
                                    }
                                </td>
                                <td>
                                    @if (volume.IsOrphaned)
                                    {
                                        <MudTooltip Text="No container mounts this volume">
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                     Color="Color.Warning" Class="dk-chip">orphaned</MudChip>
                                        </MudTooltip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="dk-chip">
                                            @volume.UsedByContainers container@(volume.UsedByContainers == 1 ? "" : "s")
                                        </MudChip>
                                    }
                                </td>
                                <td class="dk-actions">
                                    @if (Options.AllowContainerControl)
                                    {
                                        <MudTooltip Text="@(volume.IsOrphaned ? "Remove" : "In use by a container")">
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                           Disabled="@(!volume.IsOrphaned)"
                                                           OnClick="@(() => RemoveVolume(volume))" />
                                        </MudTooltip>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="@($"Networks ({_snapshot.Networks.Length})")" Icon="@Icons.Material.Filled.Hub">
            @if (Options.AllowCreate)
            {
                <div class="d-flex justify-end mb-3">
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Small" OnClick="NewNetwork">
                        New network
                    </MudButton>
                </div>
            }

            <MudSimpleTable Dense="true" Hover="true" Elevation="0" Class="dk-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Driver</th>
                        <th>Scope</th>
                        <th>Subnet</th>
                        <th>Containers</th>
                        <th class="dk-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var network in _snapshot.Networks.OrderBy(n => n.Name, StringComparer.Ordinal))
                    {
                        <tr>
                            <td>
                                <b>@network.Name</b>
                                @if (network.Driver is "macvlan" or "ipvlan")
                                {
                                    @* Whether the host can reach these containers is the first thing
                                       anyone wants to know about a macvlan, and it is invisible
                                       otherwise — it presents as a container that will not respond. *@
                                    @if (Shim.IsInstalled(network.Name))
                                    {
                                        <MudTooltip Text="This server has a shim interface for this network, so it can reach these containers.">
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                     Color="Color.Success" Class="ml-2 dk-chip">reachable</MudChip>
                                        </MudTooltip>
                                    }
                                    else
                                    {
                                        <MudTooltip Text="Containers here have their own LAN address, but this server cannot reach them (macvlan isolation). Recreate the network with the shim option to change that.">
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                     Color="Color.Default" Class="ml-2 dk-chip">isolated from host</MudChip>
                                        </MudTooltip>
                                    }
                                }
                            </td>
                            <td class="mud-text-secondary">@network.Driver</td>
                            <td class="mud-text-secondary">@network.Scope</td>
                            <td class="mud-text-secondary dk-mono">
                                @(network.Subnets.Length > 0 ? string.Join(", ", network.Subnets) : "—")
                            </td>
                            <td class="dk-numeric">@network.UsedByContainers</td>
                            <td class="dk-actions">
                                @if (Options.AllowContainerControl)
                                {
                                    <MudTooltip Text="@(network.IsBuiltIn ? "Built-in network" : network.UsedByContainers > 0 ? "In use" : "Remove")">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                       Disabled="@(network.IsBuiltIn || network.UsedByContainers > 0)"
                                                       OnClick="@(() => RemoveNetwork(network))" />
                                    </MudTooltip>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudTabPanel>

    </MudTabs>

    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-4">
        Polled every @Options.PollIntervalSeconds.ToString("0.#")s &middot; last update
        @_snapshot.TimestampUtc.ToLocalTime().ToString("HH:mm:ss")
    </MudText>
}

@code {
    private IDisposable? _subscription;
    private DockerSnapshot? _snapshot;
    private bool _composeAvailable;

    // Ids with an action in flight. A second click before the poller catches up would issue a
    // duplicate command against a container that is already changing.
    private readonly HashSet<string> _busy = [];

    // Compose operations take minutes and act on a whole project, so one at a time: `up` and
    // `down` racing on the same project would fight over the same containers.
    private string? _projectBusy;

    protected override async Task OnInitializedAsync()
    {
        _snapshot = Poller.Latest;
        _subscription = EventBus.Subscribe<DockerSnapshot>(OnSnapshot);
        _composeAvailable = await Compose.IsAvailableAsync();
    }

    private static Color ProjectColor(ComposeProject project) => project.Status switch
    {
        ComposeProjectStatus.Running => Color.Success,
        ComposeProjectStatus.Partial => Color.Warning,
        ComposeProjectStatus.Stopped => Color.Default,
        _ => Color.Default,
    };

    private static string ProjectLabel(ComposeProject project) => project.Status switch
    {
        ComposeProjectStatus.Running => $"running ({project.RunningCount})",
        ComposeProjectStatus.Partial => $"partial ({project.RunningCount}/{project.ContainerCount})",
        ComposeProjectStatus.Stopped => "stopped",
        _ => "not created",
    };

    /// <summary>
    /// Runs a compose operation. Kept separate from the container-level Run: these take minutes,
    /// so the project shows a spinner and every button on the page is disabled meanwhile.
    /// </summary>
    private async Task RunProject(ComposeProject project, string pastTense, Func<Task<DockerActionResult>> action)
    {
        _projectBusy = project.Name;

        try
        {
            var result = await action();

            Snackbar.Add(
                result.Succeeded ? $"{pastTense} {project.Name}." : result.Message,
                result.Succeeded ? Severity.Success : Severity.Error,
                config => config.VisibleStateDuration = result.Succeeded ? 4000 : 15000);
        }
        finally
        {
            _projectBusy = null;
        }
    }

    /// <summary>
    /// Deletes a project outright. Separate from Down, which only removes the containers.
    /// </summary>
    private async Task DeleteProject(ComposeProject project)
    {
        var hasVolumes = project.Containers.Any(c => c.VolumeMounts.Length > 0);

        var parameters = new DialogParameters<DeleteProjectDialog>
        {
            { x => x.ProjectName, project.Name },
            { x => x.ComposeFile, project.ConfigFiles.FirstOrDefault() ?? string.Empty },
            { x => x.HasVolumes, hasVolumes },
        };

        var dialog = await DialogService.ShowAsync<DeleteProjectDialog>(
            $"Delete {project.Name}",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });

        if (await dialog.Result is not { Canceled: false, Data: bool removeVolumes })
        {
            return;
        }

        await RunProject(project, "Deleted", () => Compose.DeleteAsync(project, removeVolumes));
    }

    private async Task DownProject(ComposeProject project)
    {
        if (!await Confirm(
            $"Take '{project.Name}' down?",
            "Its containers and networks are stopped and removed. Named volumes and their data are kept.",
            "Down"))
        {
            return;
        }

        await RunProject(project, "Took down", () => Compose.DownAsync(project));
    }

    private async Task NewProject()
    {
        var dialog = await DialogService.ShowAsync<ComposeEditorDialog>(
            "New compose project",
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });

        var result = await dialog.Result;

        if (result is not { Canceled: false, Data: string name })
        {
            return;
        }

        // The file is written but nothing is running yet; bring it up so "Create and start" means
        // what it says. Discovery only finds it on the next poll, so build the project here.
        var created = new ComposeProject
        {
            Name = name,
            WorkingDirectory = Compose.DirectoryFor(name),
            ConfigFiles = [Compose.ComposeFileFor(name)],
            IsManaged = true,
        };

        await RunProject(created, "Created and started", () => Compose.UpAsync(created));
    }

    private async Task EditProject(ComposeProject project)
    {
        var yaml = await Compose.ReadConfigFileAsync(project);

        if (yaml is null)
        {
            Snackbar.Add($"Could not read the compose file for {project.Name}.", Severity.Error);

            return;
        }

        var parameters = new DialogParameters<ComposeEditorDialog>
        {
            { x => x.ProjectName, project.Name },
            { x => x.Yaml, yaml },
        };

        var dialog = await DialogService.ShowAsync<ComposeEditorDialog>(
            $"Edit {project.Name}",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });

        if (await dialog.Result is not { Canceled: false })
        {
            return;
        }

        // Saving only writes the file; `up` is what makes the change real.
        await RunProject(project, "Applied", () => Compose.UpAsync(project));
    }

    private async Task NewContainer()
    {
        var parameters = new DialogParameters<CreateContainerDialog>
        {
            { x => x.Networks, _snapshot?.Networks.Select(n => n.Name).ToList() ?? [] },
        };

        var dialog = await DialogService.ShowAsync<CreateContainerDialog>(
            "New container",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });

        if (await dialog.Result is { Canceled: false, Data: string name })
        {
            Snackbar.Add($"Created {name}.", Severity.Success);
            await RefreshAsync();
        }
    }

    private async Task NewVolume()
    {
        var dialog = await DialogService.ShowAsync<CreateVolumeDialog>("New volume");

        if (await dialog.Result is { Canceled: false, Data: string name })
        {
            Snackbar.Add($"Created volume {name}.", Severity.Success);
        }
    }

    private async Task NewNetwork()
    {
        var dialog = await DialogService.ShowAsync<CreateNetworkDialog>(
            "New network",
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });

        if (await dialog.Result is { Canceled: false, Data: string name })
        {
            Snackbar.Add($"Created network {name}.", Severity.Success);
        }
    }

    private Task OnSnapshot(DockerSnapshot snapshot, CancellationToken cancellationToken)
    {
        _snapshot = snapshot;

        // Published from the poller's thread; InvokeAsync marshals onto the circuit.
        return InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Running containers first, then by compose project, then by name — so the things that are
    /// actually serving traffic are at the top rather than sorted among stopped leftovers.
    /// </summary>
    private IEnumerable<DockerContainer> OrderedContainers =>
        _snapshot!.Containers
            .OrderByDescending(c => c.IsRunning)
            .ThenBy(c => c.ComposeProject ?? "￿", StringComparer.Ordinal)
            .ThenBy(c => c.Name, StringComparer.Ordinal);

    private bool IsBusy(DockerContainer container) => _busy.Contains(container.Id);

    private static Color StateColor(DockerContainer container) => container.State switch
    {
        ContainerState.Running when container.Health == "unhealthy" => Color.Warning,
        ContainerState.Running => Color.Success,
        ContainerState.Restarting => Color.Warning,
        ContainerState.Paused => Color.Info,
        ContainerState.Exited when container.ExitCode is not (null or 0) => Color.Error,
        ContainerState.Exited => Color.Default,
        ContainerState.Dead => Color.Error,
        _ => Color.Default,
    };

    private static string StateLabel(DockerContainer container) => container switch
    {
        // A non-zero exit is the single most useful thing to surface: "exited" alone hides
        // whether the container finished its job or crashed.
        { State: ContainerState.Exited, ExitCode: > 0 and var code } => $"exited ({code})",
        { State: ContainerState.Running, Health: "unhealthy" } => "unhealthy",
        { State: ContainerState.Running, Health: "starting" } => "starting",
        _ => container.State.ToString().ToLowerInvariant(),
    };

    /// <summary>
    /// Whether a published port can be opened from the browser. A port bound to loopback is
    /// reachable only on the server itself, so linking it would give a dead link.
    /// </summary>
    private static bool IsLinkable(PortBinding port) =>
        port.Protocol == "tcp" && port.HostIp is "0.0.0.0" or "::" or "";

    /// <summary>
    /// Link target for a published port, built from the host in the browser's own address bar.
    /// The bind address is not usable here: 0.0.0.0 means "every interface", not a destination.
    /// </summary>
    private string PortUrl(PortBinding port)
    {
        var scheme = port.ContainerPort == 443 ? "https" : "http";
        var host = Navigation.ToAbsoluteUri(Navigation.Uri).Host;

        return $"{scheme}://{host}:{port.HostPort}";
    }

    /// <summary>
    /// Runs an action against a container and reports it.
    /// </summary>
    /// <remarks>
    /// The success message is composed here, from the name the operator actually clicked.
    /// <see cref="DockerCli"/> only knows the id, and echoing a 64-character digest back at
    /// someone who clicked "stop" next to the word "cache" is not a message.  Failures still
    /// show Docker's own stderr, which says something the module could not.
    /// </remarks>
    private async Task Run(DockerContainer container, string pastTense, Func<Task<DockerActionResult>> action)
    {
        _busy.Add(container.Id);

        try
        {
            var result = await action();

            Snackbar.Add(
                result.Succeeded ? $"{pastTense} {container.Name}." : result.Message,
                result.Succeeded ? Severity.Success : Severity.Error);

            // Refresh immediately rather than waiting up to a full poll interval for the row to
            // catch up with what the operator just did.
            await RefreshAsync();
        }
        finally
        {
            _busy.Remove(container.Id);
        }
    }

    private async Task RefreshAsync()
    {
        var containers = await Cli.ListContainersAsync();

        if (_snapshot is not null)
        {
            _snapshot = _snapshot with { Containers = containers, TimestampUtc = DateTimeOffset.UtcNow };
            StateHasChanged();
        }
    }

    private async Task ShowLogs(DockerContainer container)
    {
        var parameters = new DialogParameters<LogsDialog>
        {
            { x => x.ContainerId, container.Id },
            { x => x.ContainerName, container.Name },
        };

        await DialogService.ShowAsync<LogsDialog>(
            $"Logs: {container.Name}",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true });
    }

    private async Task RemoveContainer(DockerContainer container)
    {
        var running = container.IsRunning;

        if (!await Confirm(
            $"Remove container '{container.Name}'?",
            running
                ? "It is running and will be killed first. Anything not on a volume is lost."
                : "Anything written inside the container that is not on a volume is lost.",
            "Remove"))
        {
            return;
        }

        _busy.Add(container.Id);

        try
        {
            var result = await Cli.RemoveContainerAsync(container.Id, force: running);

            Snackbar.Add(
                result.Succeeded ? $"Removed {container.Name}." : result.Message,
                result.Succeeded ? Severity.Success : Severity.Error);

            await RefreshAsync();
        }
        finally
        {
            _busy.Remove(container.Id);
        }
    }

    private async Task RemoveImage(DockerImage image)
    {
        if (!await Confirm(
            $"Remove image '{image.DisplayName}'?",
            "Any container created from it later will have to pull it again.",
            "Remove"))
        {
            return;
        }

        var result = await Cli.RemoveImageAsync(image.Id);
        Snackbar.Add(result.Message, result.Succeeded ? Severity.Success : Severity.Error);
    }

    private async Task RemoveVolume(DockerVolume volume)
    {
        if (!await Confirm(
            $"Remove volume '{volume.Name}'?",
            "The data in this volume is deleted permanently and is not recoverable from here.",
            "Remove"))
        {
            return;
        }

        var result = await Cli.RemoveVolumeAsync(volume.Name);
        Snackbar.Add(result.Message, result.Succeeded ? Severity.Success : Severity.Error);
    }

    private async Task RemoveNetwork(DockerNetwork network)
    {
        if (!await Confirm($"Remove network '{network.Name}'?", null, "Remove"))
        {
            return;
        }

        var result = await Cli.RemoveNetworkAsync(network.Id, network.Name);
        Snackbar.Add(result.Message, result.Succeeded ? Severity.Success : Severity.Error);
    }

    private async Task PruneImages()
    {
        var count = _snapshot?.Images.Count(i => i.IsDangling) ?? 0;

        if (!await Confirm(
            $"Remove {count} dangling image{(count == 1 ? "" : "s")}?",
            "Dangling images are untagged leftovers of a rebuild. Nothing running depends on them.",
            "Prune"))
        {
            return;
        }

        var result = await Cli.PruneImagesAsync();
        Snackbar.Add(result.Message, result.Succeeded ? Severity.Success : Severity.Error);
    }

    private async Task<bool> Confirm(string message, string? detail, string confirmText)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Message, message },
            { x => x.Detail, detail },
            { x => x.ConfirmText, confirmText },
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(confirmText, parameters);
        var result = await dialog.Result;

        return result is { Canceled: false };
    }

    public void Dispose()
    {
        // Without this the bus holds this component for the life of the process.
        _subscription?.Dispose();
    }
}
