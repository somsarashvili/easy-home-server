@* Confirmation for actions that take the server away from you. The confirm button is
   deliberately not the default focus. *@

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body1">@Message</MudText>

        @if (Detail is not null)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2">@Detail</MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="@ConfirmColor" Variant="Variant.Filled" OnClick="Confirm">@ConfirmText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance Dialog { get; set; } = default!;

    /// <summary>The question being asked.</summary>
    [Parameter]
    public string Message { get; set; } = "Are you sure?";

    /// <summary>Optional secondary line spelling out the consequence.</summary>
    [Parameter]
    public string? Detail { get; set; }

    /// <summary>Label for the confirming button.</summary>
    [Parameter]
    public string ConfirmText { get; set; } = "Confirm";

    /// <summary>Colour of the confirming button.</summary>
    [Parameter]
    public Color ConfirmColor { get; set; } = Color.Error;

    private void Confirm()
    {
        Dialog.Close(DialogResult.Ok(true));
    }

    private void Cancel()
    {
        Dialog.Cancel();
    }
}
